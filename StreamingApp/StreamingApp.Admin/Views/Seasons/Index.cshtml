@model IReadOnlyList<SeasonListItemViewModel>

@{
    ViewData["Title"] = "Seasons";
}

<section class="admin-page">
    <div class="admin-page-header">
        <div>
            <p class="admin-eyebrow">Content</p>
            <h1>Seasons</h1>
        </div>
        <a class="btn btn-primary" asp-action="Create">New Season</a>
    </div>

    @if (Model.Count == 0)
    {
        <div class="admin-empty">
            <h2>No seasons yet</h2>
            <p>Create a series first, then add seasons to it.</p>
        </div>
    }
    else
    {
        <div class="admin-table-wrap">
            <table class="table admin-table align-middle">
                <thead>
                <tr>
                    <th>Series</th>
                    <th>Season</th>
                    <th>Title</th>
                    <th>Episodes</th>
                    <th class="text-end">Actions</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var season in Model)
                {
                    <tr>
                        <td>@season.SeriesTitle</td>
                        <td>@season.SeasonNumber</td>
                        <td>@season.Title</td>
                        <td>@season.EpisodeCount</td>
                        <td class="admin-row-actions">
                            <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@season.Id">Edit</a>
                            <form asp-action="Delete" asp-route-id="@season.Id" method="post" onsubmit="return confirm('Delete this season and its episodes?');">
                                @Html.AntiForgeryToken()
                                <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</section>
