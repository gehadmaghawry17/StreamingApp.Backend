@model IReadOnlyList<PromotedContentListItemViewModel>

@{
    ViewData["Title"] = "Promoted Content";
}

<section class="admin-page">
    <div class="admin-page-header">
        <div>
            <p class="admin-eyebrow">Platform</p>
            <h1>Promoted Content</h1>
            <p class="admin-subtitle">Manage carousel and discovery placements.</p>
        </div>
        <a class="btn btn-primary" asp-action="Create">New Promotion</a>
    </div>

    @if (Model.Count == 0)
    {
        <div class="admin-empty">
            <h2>No promoted content yet</h2>
            <p>Add movies or series to feature them in app surfaces.</p>
        </div>
    }
    else
    {
        <div class="admin-table-wrap">
            <table class="table admin-table align-middle">
                <thead>
                <tr>
                    <th>Label</th>
                    <th>Content</th>
                    <th>Order</th>
                    <th>Active</th>
                    <th class="text-end">Actions</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Label</td>
                        <td>@item.ContentType #@item.ContentId</td>
                        <td>@item.DisplayOrder</td>
                        <td>@(item.IsActive ? "Yes" : "No")</td>
                        <td class="admin-row-actions">
                            <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@item.Id">Edit</a>
                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Delete this promotion?');">
                                @Html.AntiForgeryToken()
                                <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</section>
