@model IReadOnlyList<EpisodeListItemViewModel>

@{
    ViewData["Title"] = "Episodes";
}

<section class="admin-page">
    <div class="admin-page-header">
        <div>
            <p class="admin-eyebrow">Content</p>
            <h1>Episodes</h1>
        </div>
        <a class="btn btn-primary" asp-action="Create">New Episode</a>
    </div>

    @if (Model.Count == 0)
    {
        <div class="admin-empty">
            <h2>No episodes yet</h2>
            <p>Create a season first, then add episodes to it.</p>
        </div>
    }
    else
    {
        <div class="admin-table-wrap">
            <table class="table admin-table align-middle">
                <thead>
                <tr>
                    <th>Series</th>
                    <th>Season</th>
                    <th>Episode</th>
                    <th>Title</th>
                    <th>Duration</th>
                    <th class="text-end">Actions</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var episode in Model)
                {
                    <tr>
                        <td>@episode.SeriesTitle</td>
                        <td>@episode.SeasonTitle</td>
                        <td>@episode.EpisodeNumber</td>
                        <td>@episode.Title</td>
                        <td>@episode.DurationSeconds sec</td>
                        <td class="admin-row-actions">
                            <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@episode.Id">Edit</a>
                            <form asp-action="Delete" asp-route-id="@episode.Id" method="post" onsubmit="return confirm('Delete this episode?');">
                                @Html.AntiForgeryToken()
                                <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</section>
