@model ReviewFormViewModel

@{
    ViewData["Title"] = "Moderate Review";
}

<section class="admin-page admin-form-page">
    <div class="admin-page-header">
        <div>
            <p class="admin-eyebrow">Engagement</p>
            <h1>Moderate Review</h1>
            <p class="admin-subtitle">@Model.UserEmail - @Model.ContentType #@Model.ContentId</p>
        </div>
        <a class="btn btn-outline-secondary" asp-action="Index">Back</a>
    </div>

    <form class="admin-form" asp-action="Edit" asp-route-id="@Model.Id" method="post">
        @Html.AntiForgeryToken()
        <input asp-for="Id" type="hidden" />
        <input asp-for="UserEmail" type="hidden" />
        <input asp-for="ContentType" type="hidden" />
        <input asp-for="ContentId" type="hidden" />
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="admin-form-grid">
            <div class="admin-field admin-field-wide">
                <label class="form-label" asp-for="Body"></label>
                <textarea class="form-control" asp-for="Body" rows="6"></textarea>
                <span class="text-danger" asp-validation-for="Body"></span>
            </div>

            <div class="admin-field">
                <label class="form-label" asp-for="IsApproved"></label>
                <div class="form-check admin-check">
                    <input class="form-check-input" asp-for="IsApproved" />
                    <label class="form-check-label" asp-for="IsApproved">Approved</label>
                </div>
            </div>
        </div>

        <div class="admin-form-actions">
            <button class="btn btn-primary" type="submit">Save</button>
            <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
