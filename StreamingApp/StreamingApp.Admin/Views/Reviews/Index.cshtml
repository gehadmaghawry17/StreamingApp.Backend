@model IReadOnlyList<ReviewListItemViewModel>

@{
    ViewData["Title"] = "Reviews";
}

<section class="admin-page">
    <div class="admin-page-header">
        <div>
            <p class="admin-eyebrow">Engagement</p>
            <h1>Reviews</h1>
            <p class="admin-subtitle">Approve, edit, or remove user reviews.</p>
        </div>
    </div>

    @if (Model.Count == 0)
    {
        <div class="admin-empty">
            <h2>No reviews yet</h2>
            <p>User-submitted reviews will appear here.</p>
        </div>
    }
    else
    {
        <div class="admin-table-wrap">
            <table class="table admin-table align-middle">
                <thead>
                <tr>
                    <th>User</th>
                    <th>Content</th>
                    <th>Review</th>
                    <th>Approved</th>
                    <th>Created</th>
                    <th class="text-end">Actions</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var review in Model)
                {
                    <tr>
                        <td>@review.UserEmail</td>
                        <td>@review.ContentType #@review.ContentId</td>
                        <td>@review.BodyPreview</td>
                        <td>@(review.IsApproved ? "Yes" : "No")</td>
                        <td>@review.CreatedAt.ToString("yyyy-MM-dd")</td>
                        <td class="admin-row-actions">
                            <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@review.Id">Moderate</a>
                            <form asp-action="Delete" asp-route-id="@review.Id" method="post" onsubmit="return confirm('Delete this review?');">
                                @Html.AntiForgeryToken()
                                <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</section>
