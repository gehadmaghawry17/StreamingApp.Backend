@model IReadOnlyList<StreamingApp.Domain.Entities.Genre>

@{
    ViewData["Title"] = "Genres";
}

<section class="admin-page">
    <div class="admin-page-header">
        <div>
            <p class="admin-eyebrow">Content</p>
            <h1>Genres</h1>
            <p class="admin-subtitle">Create categories that can be attached to movies and series.</p>
        </div>
        <a class="btn btn-primary" asp-action="Create">New Genre</a>
    </div>

    @if (Model.Count == 0)
    {
        <div class="admin-empty">
            <h2>No genres yet</h2>
            <p>Add genres like Action, Drama, Comedy, Documentary, or Sci-Fi.</p>
        </div>
    }
    else
    {
        <div class="admin-table-wrap">
            <table class="table admin-table align-middle">
                <thead>
                <tr>
                    <th>Name</th>
                    <th class="text-end">Actions</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var genre in Model)
                {
                    <tr>
                        <td>@genre.Name</td>
                        <td class="admin-row-actions">
                            <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@genre.Id">Edit</a>
                            <form asp-action="Delete" asp-route-id="@genre.Id" method="post" onsubmit="return confirm('Delete this genre?');">
                                @Html.AntiForgeryToken()
                                <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</section>
