@model MovieFormViewModel

<div asp-validation-summary="ModelOnly" class="text-danger"></div>

<div class="admin-form-grid">
    <div class="admin-field">
        <label class="form-label" asp-for="Title"></label>
        <input class="form-control" asp-for="Title" autocomplete="off" />
        <span class="text-danger" asp-validation-for="Title"></span>
    </div>

    <div class="admin-field">
        <label class="form-label" asp-for="Slug"></label>
        <input class="form-control" asp-for="Slug" autocomplete="off" />
        <div class="admin-field-meta">Leave empty to generate from title.</div>
        <span class="text-danger" asp-validation-for="Slug"></span>
    </div>

    <div class="admin-field admin-field-wide">
        <label class="form-label" asp-for="Description"></label>
        <textarea class="form-control" asp-for="Description" rows="4"></textarea>
        <span class="text-danger" asp-validation-for="Description"></span>
    </div>

    <div class="admin-field">
        <label class="form-label" asp-for="ThumbnailUrl"></label>
        <input class="form-control" asp-for="ThumbnailUrl" />
        <span class="text-danger" asp-validation-for="ThumbnailUrl"></span>
    </div>

    <div class="admin-field">
        <label class="form-label" asp-for="TrailerUrl"></label>
        <input class="form-control" asp-for="TrailerUrl" />
        <span class="text-danger" asp-validation-for="TrailerUrl"></span>
    </div>

    <div class="admin-field">
        <label class="form-label" asp-for="VideoUrl"></label>
        <input class="form-control" asp-for="VideoUrl" />
        <span class="text-danger" asp-validation-for="VideoUrl"></span>
    </div>

    <div class="admin-field">
        <label class="form-label" asp-for="DurationSeconds"></label>
        <input class="form-control" asp-for="DurationSeconds" type="number" min="1" />
        <span class="text-danger" asp-validation-for="DurationSeconds"></span>
    </div>

    <div class="admin-field">
        <label class="form-label" asp-for="ReleaseYear"></label>
        <input class="form-control" asp-for="ReleaseYear" type="number" min="1888" />
        <span class="text-danger" asp-validation-for="ReleaseYear"></span>
    </div>

    <div class="admin-field">
        <label class="form-label" asp-for="IsPublished"></label>
        <div class="form-check admin-check">
            <input class="form-check-input" asp-for="IsPublished" />
            <label class="form-check-label" asp-for="IsPublished">Published</label>
        </div>
    </div>

    <div class="admin-field admin-field-wide">
        <label class="form-label">Genres</label>
        <div class="admin-check-list">
            @if (Model.Genres.Count == 0)
            {
                <p class="text-muted m-0">No genres yet. Create genres first.</p>
            }
            else
            {
                @foreach (var genre in Model.Genres)
                {
                    <label class="form-check">
                        <input class="form-check-input" type="checkbox" name="SelectedGenreIds" value="@genre.Id" checked="@genre.IsSelected" />
                        <span class="form-check-label">@genre.Name</span>
                    </label>
                }
            }
        </div>
    </div>
</div>

<div class="admin-form-actions">
    <button class="btn btn-primary" type="submit">Save</button>
    <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
</div>
