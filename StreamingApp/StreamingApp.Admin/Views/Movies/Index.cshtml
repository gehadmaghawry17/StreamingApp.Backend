@model IReadOnlyList<MovieListItemViewModel>

@{
    ViewData["Title"] = "Movies";
}

<section class="admin-page">
    <div class="admin-page-header">
        <div>
            <p class="admin-eyebrow">Content</p>
            <h1>Movies</h1>
            <p class="admin-subtitle">Manage standalone movie records and their genre links.</p>
        </div>
        <a class="btn btn-primary" asp-action="Create">New Movie</a>
    </div>

    @if (Model.Count == 0)
    {
        <div class="admin-empty">
            <h2>No movies yet</h2>
            <p>Create a movie after adding at least one genre.</p>
        </div>
    }
    else
    {
        <div class="admin-table-wrap">
            <table class="table admin-table align-middle">
                <thead>
                <tr>
                    <th>Title</th>
                    <th>Slug</th>
                    <th>Year</th>
                    <th>Published</th>
                    <th>Genres</th>
                    <th class="text-end">Actions</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var movie in Model)
                {
                    <tr>
                        <td>@movie.Title</td>
                        <td>@movie.Slug</td>
                        <td>@movie.ReleaseYear</td>
                        <td>@(movie.IsPublished ? "Yes" : "No")</td>
                        <td>@(string.IsNullOrWhiteSpace(movie.Genres) ? "None" : movie.Genres)</td>
                        <td class="admin-row-actions">
                            <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@movie.Id">Edit</a>
                            <form asp-action="Delete" asp-route-id="@movie.Id" method="post" onsubmit="return confirm('Delete this movie?');">
                                @Html.AntiForgeryToken()
                                <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</section>
