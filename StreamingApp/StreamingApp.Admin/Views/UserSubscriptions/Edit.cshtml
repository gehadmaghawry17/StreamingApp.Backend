@model UserSubscriptionFormViewModel

@{
    ViewData["Title"] = "Edit User Subscription";
}

<section class="admin-page admin-form-page">
    <div class="admin-page-header">
        <div>
            <p class="admin-eyebrow">Subscriptions</p>
            <h1>Edit User Subscription</h1>
        </div>
        <a class="btn btn-outline-secondary" asp-action="Index">Back</a>
    </div>

    <form class="admin-form" asp-action="Edit" asp-route-id="@Model.Id" method="post">
        @Html.AntiForgeryToken()
        <input asp-for="Id" type="hidden" />
        <partial name="_UserSubscriptionForm" model="Model" />
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
