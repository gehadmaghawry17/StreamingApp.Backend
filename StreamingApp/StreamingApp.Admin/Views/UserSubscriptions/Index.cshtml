@model IReadOnlyList<UserSubscriptionListItemViewModel>

@{
    ViewData["Title"] = "User Subscriptions";
}

<section class="admin-page">
    <div class="admin-page-header">
        <div>
            <p class="admin-eyebrow">Subscriptions</p>
            <h1>User Subscriptions</h1>
        </div>
        <a class="btn btn-primary" asp-action="Create">New Subscription</a>
    </div>

    @if (Model.Count == 0)
    {
        <div class="admin-empty">
            <h2>No user subscriptions yet</h2>
            <p>Create users and plans before assigning subscriptions.</p>
        </div>
    }
    else
    {
        <div class="admin-table-wrap">
            <table class="table admin-table align-middle">
                <thead>
                <tr>
                    <th>User</th>
                    <th>Plan</th>
                    <th>Status</th>
                    <th>Start</th>
                    <th>End</th>
                    <th>Auto Renew</th>
                    <th class="text-end">Actions</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var subscription in Model)
                {
                    <tr>
                        <td>@subscription.UserEmail</td>
                        <td>@subscription.PlanName</td>
                        <td>@subscription.Status</td>
                        <td>@subscription.StartDate.ToString("yyyy-MM-dd")</td>
                        <td>@subscription.EndDate.ToString("yyyy-MM-dd")</td>
                        <td>@(subscription.AutoRenew ? "Yes" : "No")</td>
                        <td class="admin-row-actions">
                            <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@subscription.Id">Edit</a>
                            <form asp-action="Delete" asp-route-id="@subscription.Id" method="post" onsubmit="return confirm('Delete this subscription?');">
                                @Html.AntiForgeryToken()
                                <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</section>
