@model AdminDashboardViewModel

@{
    ViewData["Title"] = "Admin";
}

<section class="admin-page">
    <div class="admin-page-header">
        <div>
            <p class="admin-eyebrow">StreamView</p>
            <h1>Admin Dashboard</h1>
        </div>
        <a class="btn btn-outline-secondary" href="http://localhost:5062/openapi/v1.json">API Schema</a>
    </div>

    <div class="admin-grid">
        <article class="admin-card">
            <div>
                <h2>Genres</h2>
                <p>Content categories used by movies and series.</p>
            </div>
            <div class="admin-card-meta">
                <span>@Model.GenreCount rows</span>
                <a class="btn btn-sm btn-primary" asp-controller="Genres" asp-action="Index">Open</a>
            </div>
        </article>

        <article class="admin-card">
            <div>
                <h2>Movies</h2>
                <p>Standalone films with trailer, video URL, and genres.</p>
            </div>
            <div class="admin-card-meta">
                <span>@Model.MovieCount rows</span>
                <a class="btn btn-sm btn-primary" asp-controller="Movies" asp-action="Index">Open</a>
            </div>
        </article>

        <article class="admin-card">
            <div>
                <h2>Series</h2>
                <p>Series records with genre links and future seasons.</p>
            </div>
            <div class="admin-card-meta">
                <span>@Model.SeriesCount rows</span>
                <a class="btn btn-sm btn-primary" asp-controller="Series" asp-action="Index">Open</a>
            </div>
        </article>

        <article class="admin-card">
            <div>
                <h2>Seasons</h2>
                <p>Season records under series.</p>
            </div>
            <div class="admin-card-meta">
                <span>@Model.SeasonCount rows</span>
                <a class="btn btn-sm btn-primary" asp-controller="Seasons" asp-action="Index">Open</a>
            </div>
        </article>

        <article class="admin-card">
            <div>
                <h2>Episodes</h2>
                <p>Episode records under seasons.</p>
            </div>
            <div class="admin-card-meta">
                <span>@Model.EpisodeCount rows</span>
                <a class="btn btn-sm btn-primary" asp-controller="Episodes" asp-action="Index">Open</a>
            </div>
        </article>

        <article class="admin-card">
            <div>
                <h2>Users</h2>
                <p>Manage account email and verification state.</p>
            </div>
            <div class="admin-card-meta">
                <span>@Model.UserCount rows</span>
                <a class="btn btn-sm btn-primary" asp-controller="Users" asp-action="Index">Open</a>
            </div>
        </article>

        <article class="admin-card">
            <div>
                <h2>Plans</h2>
                <p>Subscription plan pricing and duration.</p>
            </div>
            <div class="admin-card-meta">
                <span>@Model.SubscriptionPlanCount rows</span>
                <a class="btn btn-sm btn-primary" asp-controller="SubscriptionPlans" asp-action="Index">Open</a>
            </div>
        </article>

        <article class="admin-card">
            <div>
                <h2>User Subscriptions</h2>
                <p>Assign and manage user subscription state.</p>
            </div>
            <div class="admin-card-meta">
                <span>@Model.UserSubscriptionCount rows</span>
                <a class="btn btn-sm btn-primary" asp-controller="UserSubscriptions" asp-action="Index">Open</a>
            </div>
        </article>

        <article class="admin-card">
            <div>
                <h2>Reviews</h2>
                <p>Moderate submitted user reviews.</p>
            </div>
            <div class="admin-card-meta">
                <span>@Model.PendingReviewCount pending</span>
                <a class="btn btn-sm btn-primary" asp-controller="Reviews" asp-action="Index">Open</a>
            </div>
        </article>

        <article class="admin-card">
            <div>
                <h2>Promoted Content</h2>
                <p>Feature movies and series in app surfaces.</p>
            </div>
            <div class="admin-card-meta">
                <span>@Model.PromotedContentCount rows</span>
                <a class="btn btn-sm btn-primary" asp-controller="PromotedContent" asp-action="Index">Open</a>
            </div>
        </article>
    </div>
</section>
