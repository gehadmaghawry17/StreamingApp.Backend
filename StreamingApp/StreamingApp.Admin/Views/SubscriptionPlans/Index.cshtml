@model IReadOnlyList<SubscriptionPlanListItemViewModel>

@{
    ViewData["Title"] = "Subscription Plans";
}

<section class="admin-page">
    <div class="admin-page-header">
        <div>
            <p class="admin-eyebrow">Subscriptions</p>
            <h1>Plans</h1>
        </div>
        <a class="btn btn-primary" asp-action="Create">New Plan</a>
    </div>

    @if (Model.Count == 0)
    {
        <div class="admin-empty">
            <h2>No plans yet</h2>
            <p>Create monthly or yearly plans before assigning subscriptions.</p>
        </div>
    }
    else
    {
        <div class="admin-table-wrap">
            <table class="table admin-table align-middle">
                <thead>
                <tr>
                    <th>Name</th>
                    <th>Duration</th>
                    <th>Days</th>
                    <th>Price</th>
                    <th class="text-end">Actions</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var plan in Model)
                {
                    <tr>
                        <td>@plan.Name</td>
                        <td>@plan.Duration</td>
                        <td>@plan.DurationDays</td>
                        <td>@plan.Price.ToString("C")</td>
                        <td class="admin-row-actions">
                            <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@plan.Id">Edit</a>
                            <form asp-action="Delete" asp-route-id="@plan.Id" method="post" onsubmit="return confirm('Delete this plan?');">
                                @Html.AntiForgeryToken()
                                <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</section>
