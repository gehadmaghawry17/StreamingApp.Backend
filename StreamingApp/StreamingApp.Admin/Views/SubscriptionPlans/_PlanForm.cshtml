@model SubscriptionPlanFormViewModel

<div asp-validation-summary="ModelOnly" class="text-danger"></div>

<div class="admin-form-grid">
    <div class="admin-field">
        <label class="form-label" asp-for="Name"></label>
        <input class="form-control" asp-for="Name" autocomplete="off" />
        <span class="text-danger" asp-validation-for="Name"></span>
    </div>

    <div class="admin-field">
        <label class="form-label" asp-for="Duration"></label>
        <select class="form-select" asp-for="Duration" asp-items="Html.GetEnumSelectList<PlanDuration>()"></select>
        <span class="text-danger" asp-validation-for="Duration"></span>
    </div>

    <div class="admin-field">
        <label class="form-label" asp-for="Price"></label>
        <input class="form-control" asp-for="Price" type="number" min="0.01" step="0.01" />
        <span class="text-danger" asp-validation-for="Price"></span>
    </div>

    <div class="admin-field">
        <label class="form-label" asp-for="DurationDays"></label>
        <input class="form-control" asp-for="DurationDays" type="number" min="1" />
        <span class="text-danger" asp-validation-for="DurationDays"></span>
    </div>
</div>

<div class="admin-form-actions">
    <button class="btn btn-primary" type="submit">Save</button>
    <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
</div>
